<!DOCTYPE html>
<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>You're invited to Pikslots</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background-color: #f5f0f5;
        font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 14px;
        line-height: 1.6;
        color: #1a1523;
        -webkit-font-smoothing: antialiased;
      }

      .wrapper {
        width: 100%;
        padding: 40px 16px;
        background-color: #f5f0f5;
      }

      .container {
        max-width: 520px;
        margin: 0 auto;
        background-color: #ffffff;
        border: 1px solid #e8e0e8;
      }

      /* Header */
      .header {
        padding: 32px 40px 28px;
        border-bottom: 1px solid #e8e0e8;
      }

      .logo {
        font-size: 18px;
        font-weight: 600;
        color: #1a1523;
        letter-spacing: -0.02em;
        text-decoration: none;
      }

      .logo span {
        color: #4f46e5;
      }

      /* Body */
      .body {
        padding: 36px 40px;
      }

      .greeting {
        font-size: 22px;
        font-weight: 600;
        color: #1a1523;
        letter-spacing: -0.02em;
        margin-bottom: 12px;
      }

      .intro {
        color: #6b6075;
        font-size: 14px;
        margin-bottom: 28px;
        line-height: 1.6;
      }

      /* Info card */
      .info-card {
        background-color: #f5f0f5;
        border: 1px solid #e8e0e8;
        padding: 20px 24px;
        margin-bottom: 28px;
      }

      .info-row {
        display: flex;
        margin-bottom: 10px;
      }

      .info-row:last-child {
        margin-bottom: 0;
      }

      .info-label {
        font-size: 12px;
        font-weight: 500;
        color: #6b6075;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        width: 80px;
        flex-shrink: 0;
        padding-top: 1px;
      }

      .info-value {
        font-size: 14px;
        font-weight: 500;
        color: #1a1523;
      }

      /* Role badge */
      .badge {
        display: inline-block;
        background-color: #eef2ff;
        color: #4f46e5;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 2px 8px;
        text-transform: uppercase;
      }

      /* CTA button */
      .btn-wrapper {
        margin-bottom: 28px;
      }

      .btn {
        display: inline-block;
        background-color: #4f46e5;
        color: #eef2ff !important;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        padding: 10px 24px;
        letter-spacing: 0.01em;
      }

      .note {
        font-size: 13px;
        color: #6b6075;
        line-height: 1.6;
      }

      .note a {
        color: #4f46e5;
        text-decoration: underline;
      }

      /* Divider */
      .divider {
        border: none;
        border-top: 1px solid #e8e0e8;
        margin: 28px 0;
      }

      /* Footer */
      .footer {
        padding: 20px 40px 28px;
        border-top: 1px solid #e8e0e8;
      }

      .footer-text {
        font-size: 12px;
        color: #6b6075;
        line-height: 1.6;
      }

      .footer-text a {
        color: #6b6075;
        text-decoration: underline;
      }

      @media only screen and (max-width: 560px) {
        .header, .body, .footer { padding-left: 24px; padding-right: 24px; }
        .greeting { font-size: 18px; }
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="container">

        <!-- Header -->
        <div class="header">
          <span class="logo">Pik<span>slots</span></span>
        </div>

        <!-- Body -->
        <div class="body">
          <p class="greeting">Hi {{firstName}},</p>
          <p class="intro">
            You've been invited to join Pikslots. Your account has been created
            and is ready to use. Click the button below to set your password and
            get started.
          </p>

          <!-- Account details -->
          <div class="info-card">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td class="info-label">Email</td>
                <td class="info-value">{{email}}</td>
              </tr>
              <tr><td colspan="2" style="padding: 5px 0;"></td></tr>
              <tr>
                <td class="info-label">Role</td>
                <td class="info-value">
                  <span class="badge">{{role}}</span>
                </td>
              </tr>
            </table>
          </div>

          <!-- CTA -->
          <div class="btn-wrapper">
            <a href="{{acceptUrl}}" class="btn">Accept Invitation</a>
          </div>

          <p class="note">
            This invitation link expires in <strong>48 hours</strong>. If you
            didn't expect this email, you can safely ignore it.
          </p>

          <hr class="divider" />

          <p class="note">
            If the button above doesn't work, copy and paste this link into your
            browser:<br />
            <a href="{{acceptUrl}}">{{acceptUrl}}</a>
          </p>
        </div>

        <!-- Footer -->
        <div class="footer">
          <p class="footer-text">
            © 2026 Pikslots. All rights reserved.<br />
            You received this email because you were invited to join Pikslots.
          </p>
        </div>

      </div>
    </div>
  </body>
</html>
