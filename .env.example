# BACKEND ENV VARIABLES
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pickslots

# jwt login
JWT_SECRET=veryverysecured
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=afaqajaved
JWT_REFRESH_EXPIRES_IN=1d

# jwt invite
INVITE_JWT_SECRET=ververtverreererafaq
INVITE_JWT_EXPIRES_IN=5m

CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://*.localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3000 # backend domain
FRONTEND_PUBLIC_URL=http://localhost:5173 #Frontend domain

# swagger enabled
ENABLE_API_DOCS=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password

MAIL_HOST=afaqjaved.com
MAIL_PORT=1025
MAIL_USER=dev@pikslots.com
MAIL_PASS=anypassword
MAIL_FROM='"No Reply" <noreply@example.com>'


# S3 ENV VARIABLES 
S3_ENABLED=true
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_HOST=
S3_REGION=
S3_BUCKET_NAME=
S3_FORCED_PATH_STYLE= # required other alternatives like minio,rustfs

# FRONTEND ENV VARIABLES
VITE_API_URL=http://localhost:3000
# Root domain for tenant/app subdomain routing, e.g. "pikslots.com" in production.
# Dashboard lives at app.{VITE_APP_ROOT_DOMAIN}, tenant booking pages at {slug}.{VITE_APP_ROOT_DOMAIN}.
VITE_APP_ROOT_DOMAIN=localhost
