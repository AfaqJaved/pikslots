# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pikslots

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

#Mailpit
  MAIL_HOST=must-be-a-string
  MAIL_PORT=1025
  MAIL_USER=must-be-a-string
  MAIL_PASS=must-be-a-string
  MAIL_FROM=must-be-a-string